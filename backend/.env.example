# Copy to backend/.env and fill in what you have. Everything is optional:
# without keys the app runs with warm local fallbacks (no live transcription,
# deterministic summaries/extraction).

# Speech-to-text for voice recording
DEEPGRAM_API_KEY=

# LLM for summaries, fact extraction, and Companion replies.
# Provide EITHER an OpenAI-compatible key OR an Anthropic key (OpenAI wins if
# both are set). Works with api.openai.com or any compatible gateway:
#   direct OpenAI:  OPENAI_API_KEY=sk-...          OPENAI_MODEL=gpt-5.4-mini
#   OpenRouter:     OPENAI_API_KEY=sk-or-v1-...    OPENAI_MODEL=openai/gpt-5.4-mini
#                   OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.4-mini
ANTHROPIC_API_KEY=

JWT_SECRET=change-me
DATABASE_URL=sqlite:///aangan.db
CHROMA_PATH=./chroma_data
