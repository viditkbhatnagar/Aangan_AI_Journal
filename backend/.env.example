# Copy to backend/.env and fill in what you have. Everything is optional:
# without keys the app runs with warm local fallbacks (no live transcription,
# deterministic summaries/extraction).

# Speech-to-text for voice recording
DEEPGRAM_API_KEY=

# LLM for summaries, fact extraction, and Companion replies.
# Provide EITHER an OpenAI key OR an Anthropic key (OpenAI is preferred if
# both are set).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
ANTHROPIC_API_KEY=

JWT_SECRET=change-me
DATABASE_URL=sqlite:///aangan.db
CHROMA_PATH=./chroma_data
